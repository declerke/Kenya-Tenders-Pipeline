# Application database (port 5434 on host)
APP_DB_HOST=postgres
APP_DB_PORT=5432
APP_DB_NAME=tenders_db
APP_DB_USER=postgres
APP_DB_PASSWORD=postgres

# Airflow metadata database (port 5439 on host)
AIRFLOW_DB_HOST=postgres-airflow
AIRFLOW_DB_PORT=5432
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# Airflow secrets — generate Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your-fernet-key-here
AIRFLOW_JWT_SECRET=your-jwt-secret-here
AIRFLOW_INTERNAL_API_SECRET_KEY=your-internal-api-secret-here
AIRFLOW_WEBSERVER_SECRET_KEY=your-webserver-secret-key-here

# Airflow webserver port: 8083
# Streamlit port: 8501
